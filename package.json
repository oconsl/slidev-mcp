{
  "name": "slidev-mcp",
  "version": "1.1.0",
  "description": "MCP server for creating and managing Slidev presentations",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "slidev",
    "presentations",
    "ai"
  ],
  "type": "module",
  "bin": {
    "slidev-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:watch": "npm run build && node --test --watch dist/**/*.test.js",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "js-yaml": "^4.1.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
